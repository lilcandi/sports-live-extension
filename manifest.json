{
  "manifest_version": 3,
  "name": "赛事实时播报",
  "version": "2.0.0",
  "description": "实时播报体育赛事、电竞、运动会比分 - 中文资讯+历史搜索+未来赛程+收藏赛制",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "https://www.thesportsdb.com/*",
    "https://trade.500.com/*",
    "https://m.leisu.com/*",
    "https://api.pandascore.co/*",
    "https://liquipedia.net/*",
    "https://www.hltv.org/*",
    "https://www.vlr.gg/*",
    "https://rsshub.app/*",
    "https://v2.alapi.cn/*",
    "https://bbs.hupu.com/*",
    "http://v.juhe.cn/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}