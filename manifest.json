{
  "manifest_version": 3,
  "name": "赛事实时播报",
  "version": "2.2.0",
  "description": "60+赛事·13资讯源·热度排名 - 足球/篮球/赛车/网球/电竞 中文资讯",
  "permissions": ["storage", "alarms", "notifications", "tts"],
  "host_permissions": [
    "https://trade.500.com/*",
    "https://www.thesportsdb.com/*",
    "https://bbs.hupu.com/*",
    "https://www.dongqiudi.com/*",
    "https://www.zhibo8.cc/*",
    "https://sports.sina.com.cn/*",
    "https://sports.qq.com/*",
    "https://rsshub.app/*",
    "https://v2.alapi.cn/*",
    "http://v.juhe.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
