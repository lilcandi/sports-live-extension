{
  "manifest_version": 3,
  "name": "赛事实时播报",
  "version": "2.0.4",
  "description": "实时播报体育赛事结果 - 纯中文来源 500彩票网+TheSportsDB中文+虎扑",
  "permissions": ["storage", "alarms", "notifications", "tts"],
  "host_permissions": [
    "https://www.thesportsdb.com/*",
    "https://trade.500.com/*",
    "https://bbs.hupu.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}