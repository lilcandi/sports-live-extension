{
  "manifest_version": 3,
  "name": "赛事实时播报",
  "version": "2.1.0",
  "description": "60+赛事·热度排名·赛果结论读取 - 足球/篮球/赛车/网球/电竞",
  "permissions": ["storage", "alarms", "notifications", "tts"],
  "host_permissions": [
    "https://trade.500.com/*",
    "https://www.thesportsdb.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
